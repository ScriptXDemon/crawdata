# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://mallory:mallory@localhost:5432/mallory

# ─── LLM provider ─────────────────────────────────────────────────────────────
# "stub"       → deterministic, rule-based, no API key needed (dev / offline / CI)
# "openrouter" → Mallory chat + enrichment via OpenRouter (e.g. Gemini Flash 2.0)
# "anthropic"  → via the Anthropic API
LLM_PROVIDER=stub

# OpenRouter (set LLM_PROVIDER=openrouter to activate). Get a key at openrouter.ai.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Reference seed data ──────────────────────────────────────────────────────
# Bundled JSON loaded into the ref_* tables (the "vs KSSL" baseline).
SEED_DIR=./seed_data

# ─── Layer 1 (Crawler) Ingest API ────────────────────────────────────────────
# Used by the /api/v1/asset-proxy endpoint to fetch images/PDFs/screenshots.
# Set to http://<crawler-ip>:9090 when L2 runs on a different machine.
CRAWLER_INGEST_URL=http://localhost:9090

# ─── CORS (Layer 3 client origins, comma-separated) ──────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
