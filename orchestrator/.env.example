# Orchestrator control-plane store (SQLite default; use Postgres at scale).
DATABASE_URL=sqlite:///./orchestrator.db

# Downstream services
CRAWLER_API=http://localhost:8099
# L2 Ingest API — set to http://<l2-ip>:8000 when L2 runs on a different machine
L2_INGEST_API=http://localhost:8000

# Bundled static seed
SEED_DIR=./seed_data

CORS_ORIGINS=*
